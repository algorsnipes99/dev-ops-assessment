# --- Fleet Health Monitor Configuration ---
# Copy this file to .env and adjust values for your environment.

# Application
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleet_health
DB_USER=fleet_user
DB_PASSWORD=fleet_pass
DB_POOL_SIZE=10

# Heartbeat Feeder (optional — for continuous telemetry simulation)
FEEDER_INTERVAL=5
FEEDER_HOSTS=7
FEEDER_EVENTS=true

# Remote Diagnostic (optional — for ./ops.sh remote)
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=
